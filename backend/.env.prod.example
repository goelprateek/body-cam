# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bodycam
DB_USER=bodycam
DB_PASSWORD=change-me

# App auth
APP_JWT_SECRET=change-me-change-me-change-me-123456
APP_RECORDING_MAX_UPLOAD_SIZE=512MB
LOG_PATH=/app/logs

# LiveKit
LIVEKIT_URL=ws://livekit:7880
# Must resolve to the same production host published by infra/.env.prod LIVEKIT_DOMAIN
LIVEKIT_PUBLIC_URL=wss://livekit-bodycam.idti.dev
LIVEKIT_API_KEY=replace-me-livekit-key
LIVEKIT_API_SECRET=replace-me-livekit-secret

# Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://minio-bodycam.idti.dev
MINIO_REGION=us-east-1
MINIO_BUCKET=recordings
MINIO_ACCESS_KEY=replace-me-minio-user
MINIO_SECRET_KEY=replace-me-minio-password

# Transcript
APP_TRANSCRIPT_ENABLED=true
APP_TRANSCRIPT_ENGINE=vosk
TRANSCRIPT_VOSK_URL=ws://vosk:2700
APP_TRANSCRIPT_LANGUAGE_CODE=en-US

# Future faster-whisper engine switch:
# APP_TRANSCRIPT_ENGINE=faster-whisper
# TRANSCRIPT_FASTER_WHISPER_URL=http://faster-whisper:8001/v1/audio/transcriptions
# TRANSCRIPT_FASTER_WHISPER_MODEL=large-v3
# TRANSCRIPT_FASTER_WHISPER_TASK=transcribe
# TRANSCRIPT_FASTER_WHISPER_TIMEOUT_SECONDS=300
