# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bodycam
DB_USER=bodycam
DB_PASSWORD=change-me

# App auth
APP_JWT_SECRET=change-me-change-me-change-me-123456

# LiveKit
LIVEKIT_URL=ws://livekit:7880
# Must resolve to the same production host published by infra/.env.prod LIVEKIT_DOMAIN
LIVEKIT_PUBLIC_URL=wss://livekit-bodycam.idti.dev
LIVEKIT_API_KEY=replace-me-livekit-key
LIVEKIT_API_SECRET=replace-me-livekit-secret

# Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://minio-bodycam.idti.dev
MINIO_BUCKET=recordings
