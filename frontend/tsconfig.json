{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@features/*": ["app/features/*"],
      "@shared/*": ["app/shared/*"],
      "@env/*": ["environments/*"],
      "@app/*": ["app/*"]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  }
}
