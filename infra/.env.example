# Copy one of the environment-specific examples instead of using this file directly:
# - .env.local.example -> .env.local for local Docker runs
# - .env.prod.example  -> .env.prod for production deploys

# Database
POSTGRES_DB=bodycam
POSTGRES_USER=bodycam
POSTGRES_PASSWORD=bodycam

# App auth
APP_JWT_SECRET=change-me

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=recordings

# Transcript
TRANSCRIPT_IMAGE=hwdsl2/whisper-server:latest
TRANSCRIPT_MODEL=base
TRANSCRIPT_LANGUAGE=auto
TRANSCRIPT_DEVICE=cpu
TRANSCRIPT_COMPUTE_TYPE=int8
TRANSCRIPT_THREADS=2
TRANSCRIPT_LOCAL_ONLY=true

# TURN
TURN_REALM=bodycam.local
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpass
