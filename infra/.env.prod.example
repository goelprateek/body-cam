# Database
POSTGRES_DB=bodycam
POSTGRES_USER=bodycam
POSTGRES_PASSWORD=replace-me

# App auth
APP_JWT_SECRET=replace-me

# Deploy registry
CONTAINER_REGISTRY=registry.digitalocean.com/fleet-ops

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_PUBLIC_URL=wss://livekit.example.com
LIVEKIT_BIND_IP=0.0.0.0
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_UDP_PORT_RANGE=50000-50100

# Storage
MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-me
MINIO_BUCKET=recordings
MINIO_PUBLIC_URL=https://minio.example.com
MINIO_BIND_IP=127.0.0.1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# TURN
TURN_REALM=turn.example.com
TURN_USERNAME=replace-me
TURN_PASSWORD=replace-me
TURN_EXTERNAL_IP=203.0.113.10
TURN_BIND_IP=0.0.0.0
TURN_PORT=3478

# Database publish
DB_BIND_IP=127.0.0.1
DB_PORT_PUBLISH=5431

# Public domains
API_DOMAIN=api-bodycam.example.com
FRONTEND_DOMAIN=body-cam.idti.dev
TRAEFIK_CERT_RESOLVER=le

# Image tags
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
