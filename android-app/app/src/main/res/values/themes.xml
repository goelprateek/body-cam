<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BodyCam" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorSurfaceVariant">@color/card_background_soft</item>
        <item name="colorOutline">@color/surface_stroke</item>
        <item name="android:windowBackground">@color/screen_background</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/screen_background</item>
        <item name="android:navigationBarColor">@color/screen_background</item>
        <item name="materialCardViewStyle">@style/Widget.BodyCam.Card</item>
        <item name="materialButtonStyle">@style/Widget.BodyCam.Button</item>
        <item name="textInputStyle">@style/Widget.BodyCam.TextInputLayout</item>
    </style>

    <style name="Widget.BodyCam.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">@color/surface_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.BodyCam.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="iconTint">@color/text_inverse</item>
    </style>

    <style name="Widget.BodyCam.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/surface_stroke</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.BodyCam.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_primary_dark</item>
    </style>

    <style name="Widget.BodyCam.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/surface_stroke</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextColor">@color/text_muted</item>
    </style>
</resources>
